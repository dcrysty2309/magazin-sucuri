{
  "name": "magazin-sucuri",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/dev-stack.mjs",
    "start:app": "node scripts/dev.mjs",
    "start:web": "ng serve --proxy-config proxy.conf.json",
